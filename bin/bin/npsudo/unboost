#!/bin/bash
sed -i 's/^CPU_SCALING_MAX_FREQ_ON_AC=.*$/CPU_SCALING_MAX_FREQ_ON_AC=2400000/' /etc/tlp.conf
sed -i 's/^CPU_ENERGY_PERF_POLICY_ON_AC=.*$/CPU_ENERGY_PERF_POLICY_ON_AC=balance_power/' /etc/tlp.conf
sed -i 's/^PLATFORM_PROFILE_ON_AC=.*$/PLATFORM_PROFILE_ON_AC=balanced/' /etc/tlp.conf
systemctl restart tlp

